rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi pembantu untuk mengecek apakah user adalah Admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'akbarsupiad20@gmail.com';
    }

    // Aturan untuk koleksi Produk (Gudang Menu)
    match /products/{productId} {
      allow read: if true; // Semua orang boleh lihat menu
      allow write: if isAdmin(); // Hanya Admin yang boleh tambah/edit/hapus
    }

    // Aturan untuk koleksi User
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // Aturan untuk koleksi Pesanan (Orders)
    match /orders/{orderId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid; 
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Aturan untuk koleksi Reservasi (Buku Tamu)
    match /reservations/{reservationId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    // Aturan untuk koleksi Sampah (Recycle Bin)
    match /deleted_products/{docId} {
      allow read, write: if isAdmin(); // Hanya Admin yang punya akses ke tempat sampah
    }
  }
}
